{
  "name": "ai-robot",
  "version": "1.20.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @ai-robot/server dev",
    "dev:ui": "pnpm --filter @ai-robot/setup-ui dev",
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "doctor": "pnpm --filter @ai-robot/doctor run start",
    "setup": "node scripts/setup.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "build": {
    "allowedDeprecatedVersions": {},
    "ignoredBuiltDependencies": []
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "express": "^4.22.1",
    "ws": "^8.19.0"
  }
}
