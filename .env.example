# AI Robot Configuration

# Server
APP_HOST=0.0.0.0
APP_PORT=3000

# QQ Configuration (NapCatQQ)
QQ_ENABLED=false
QQ_HTTP_PORT=3001
QQ_WS_URL=ws://localhost:3001
QQ_NUMBER=123456789
QQ_TOKEN=

# LLM Configuration (默认: alibaba)
LLM_PROVIDER=alibaba

# 阿里云/通义 API (默认主线)
ALIBABA_API_KEY=your-api-key-here
ALIBABA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIBABA_MODEL=qwen-plus
ALIBABA_TIMEOUT=120000

# 本地模型 (可选, 设置 LLM_PROVIDER=ollama 启用)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120000

# Session Storage
SESSION_STORAGE=sqlite
SQLITE_DB_PATH=./data/sessions.db
SESSION_MAX_MESSAGES=100

# Trigger Rules
CHAT_PREFIX=/ai
PRIVATE_AUTO_REPLY=true
GROUP_AI_TRIGGER=both

# Logging (debug|info|warn|error)
LOG_LEVEL=info
