# QQ 配置 (NapCatQQ)
QQ_ENABLED=false
QQ_HTTP_PORT=3001
QQ_WS_URL=ws://localhost:3001
QQ_NUMBER=123456789

# 微信配置
WECHAT_PUPPET_TOKEN=

# LLM 配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120000

# 聊天配置
CHAT_PREFIX=/ai
GROUP_AI_TRIGGER=both
PRIVATE_AUTO_REPLY=true
MAX_MESSAGES=20

# 服务器配置
SERVER_PORT=3000

# 日志级别 (debug|info|warn|error)
LOG_LEVEL=info
